generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
}

enum TransactionOwner {
  me
  father_in_law
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  credit
  debit
}
model Transaction {
  id          String   @id @default(uuid())
  type        TransactionType
  amount      Float
  category    String
  paymentMethod PaymentMethod?
  owner         TransactionOwner  @default(me)
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
}

