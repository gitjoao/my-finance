generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}


enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  credit
  debit
}
model Transaction {
  id          String   @id @default(uuid())
  type        TransactionType
  amount      Float
  category    String
  paymentMethod PaymentMethod?
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
}

